# ============================================================
# .gitignore
# GAN-based Super-Resolution Agricultural Monitoring
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# --- Virtual environments ---
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# --- Jupyter / IPython ---
.ipynb_checkpoints
*.ipynb

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- IDE / editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# Project-specific — raw and processed data
# (do NOT commit large geospatial datasets to Git;
#  upload them to a data repository instead)
# ============================================================

# Raw data (large, externally sourced)
data/raw/
data/processed/

# Trained model weights & checkpoints
checkpoints/
*.h5
*.keras
*.pb
saved_model/

# Results (large raster outputs, per-patch CSVs)
results/bicubic/
results/srcnn/
results/srgan/
results/indices/*.tif
results/analysis/*.tif

# Generated figures (reproducible from code)
figures/

# Pipeline log
pipeline.log

# Temporary files
*.tmp
*.bak
*.orig

# NumPy patch archives (large; generated from data)
data/processed/**/*.npz

# ============================================================
# KEEP these result summary CSVs (small, essential for paper)
# ============================================================
!results/analysis/model_comparison.csv
!results/analysis/correlation_matrix.csv
!results/analysis/trend_analysis.csv
!results/analysis/vi_trends.csv
!results/analysis/morans_i.csv
!results/analysis/fourier_ndvi.csv
!results/analysis/vi_acf.csv
!results/analysis/planetscope_validation.json
